{
  "name": "roboclaw",
  "version": "0.1.0",
  "description": "React + Three.js library for simulating a 6-axis KUKA robot arm doing pick-and-place tasks on a static pedestal or a mobile platform.",
  "private": true,
  "type": "module",
  "license": "MIT",

  "main": "./src/lib/index.js",
  "module": "./src/lib/index.js",
  "exports": {
    ".": {
      "import": "./src/lib/index.js"
    },
    "./assets/*": "./public/lib-assets/*",
    "./components/*": "./src/lib/components/*",
    "./ik/*": "./src/lib/ik/*",
    "./state/*": "./src/lib/state/*"
  },
  "files": [
    "src/lib",
    "public/lib-assets",
    "README.md",
    "LICENSE"
  ],

  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview"
  },

  "peerDependencies": {
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "three": "^0.184.0",
    "urdf-loader": "^0.12.7",
    "zustand": "^5.0.0"
  },

  "devDependencies": {
    "@vitejs/plugin-react": "^6.0.2",
    "vite": "^8.0.13"
  },

  "dependencies": {
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.1",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "three": "^0.184.0",
    "urdf-loader": "^0.12.7",
    "zustand": "^5.0.13"
  }
}
